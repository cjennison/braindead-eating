# ============================================================
# Brain Dead Eating — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# NEVER commit .env.local to git. It's already in .gitignore.
# ============================================================

# ------------------------------------------------------------
# AUTH.JS (NextAuth v5)
# ------------------------------------------------------------

# A random secret used to encrypt session tokens.
# Generate one by running: npx auth secret
# Or: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth credentials.
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create a new OAuth 2.0 Client ID (Web application)
# 3. Set Authorized redirect URI to:
#      http://localhost:3000/api/auth/callback/google  (dev)
#      https://yourdomain.com/api/auth/callback/google (prod)
# 4. Copy the Client ID and Client Secret here.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ------------------------------------------------------------
# MONGODB
# ------------------------------------------------------------

# Your MongoDB connection string.
# For MongoDB Atlas (recommended — free tier available):
# 1. Go to https://cloud.mongodb.com
# 2. Create a free M0 cluster
# 3. Create a database user (Database Access → Add New User)
# 4. Whitelist your IP (Network Access → Add IP Address)
# 5. Click "Connect" → "Drivers" → copy the connection string
# 6. Replace <password> with your database user password
#
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=

# ------------------------------------------------------------
# OPENAI
# ------------------------------------------------------------

# Your OpenAI API key.
# 1. Go to https://platform.openai.com/api-keys
# 2. Create a NEW project first (see OPENAI_PROJECT_ID below)
# 3. Create an API key scoped to that project
# 4. Copy the key here (starts with sk-)
OPENAI_API_KEY=

# OpenAI Project ID for billing isolation and spend limits.
# 1. Go to https://platform.openai.com/settings
# 2. Click "Projects" in the left sidebar
# 3. Create a new project called "braindead-eating"
# 4. Set a monthly spending limit (e.g., $10/month) under the project's Limits tab
# 5. Copy the Project ID here (starts with proj_)
#
# This scopes all API usage to this project's billing,
# so a runaway bug can't blow up your entire OpenAI bill.
OPENAI_PROJECT_ID=

# ------------------------------------------------------------
# APP CONFIG
# ------------------------------------------------------------

# The public URL of your app. Used for OAuth redirects.
# Development: http://localhost:3000
# Production: https://yourdomain.com (your Vercel URL)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Maximum AI requests per user per day.
# Default: 5. Only change if you want to be more restrictive.
AI_DAILY_LIMIT=5
